APP_ENV=production
APP_URL=https://agsap.com.br/homologacao
PUBLIC_API_URL=https://agsap.com.br/homologacao/api

DB_HOST=localhost
DB_PORT=3306
DB_NAME=nome_do_banco
DB_USER=usuario_do_banco
DB_PASSWORD=senha_do_banco
DB_CHARSET=utf8mb4

JWT_SECRET=troque-por-uma-chave-longa-e-segura
JWT_ISSUER=plataforma-logistica
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
CORS_ALLOW_ORIGIN=*

# Realtime opcional. Use none, ably ou pusher.
REALTIME_PROVIDER=none
REALTIME_CHANNEL=logistica-saude
ABLY_API_KEY=
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=mt1
