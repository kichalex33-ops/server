# homologacao/.env.example
# NUNCA incluir o .env real em ZIPs ou commits!
# Copie este arquivo para .env e preencha os valores reais.

APP_ENV=production
APP_URL=https://agsap.com.br/homologacao
PUBLIC_API_URL=https://agsap.com.br/homologacao/api

DB_HOST=localhost
DB_PORT=3306
DB_NAME=NOME_DO_BANCO_AQUI
DB_USER=USUARIO_DO_BANCO_AQUI
DB_PASS=SENHA_FORTE_AQUI
DB_PASSWORD=SENHA_FORTE_AQUI

# Gerar com: openssl rand -hex 32
# Mínimo 64 chars aleatórios — não usar palavras ou nomes do projeto!
JWT_SECRET=GERE_COM_openssl_rand_hex_32_AQUI
JWT_ISSUER=plataforma-logistica
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# IMPORTANTE: nunca usar * em produção
CORS_ALLOW_ORIGIN=https://agsap.com.br

AI_PROVIDER=gemini
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI
GEMINI_MODEL=gemini-1.5-flash
AI_TIMEOUT_SECONDS=30
