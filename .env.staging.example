# H5.36 - arquivo exemplo para validar migrations em uma base de staging/cópia.
# Nunca use credenciais reais de produção aqui.
# Copie para .env.staging, preencha com o banco de teste e execute:
# php scripts/validate-migrations-staging.php --env=.env.staging

APP_ENV=staging
APP_URL=https://staging.seudominio.com.br
PUBLIC_API_URL=https://staging.seudominio.com.br/api

DB_HOST=localhost
DB_PORT=3306
DB_NAME=usuariohostgator_banco_staging
DB_USER=usuariohostgator_usuario_staging
DB_PASSWORD=senha_mysql_staging
DB_CHARSET=utf8mb4

JWT_SECRET=staging_apenas_para_teste_troque_por_valor_longo
JWT_ISSUER=plataforma-logistica-staging
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
AI_TIMEOUT_SECONDS=20

# Comunicação futura paciente. Não habilita envio sozinho; serve apenas como configuração planejada.
COMM_PROVIDER=disabled
WHATSAPP_PROVIDER=disabled
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
SMS_PROVIDER=disabled
SMS_API_URL=
SMS_API_TOKEN=
